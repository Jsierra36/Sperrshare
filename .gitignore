# This repo is PUBLIC (GitHub Pages). Only app/ and landing/ belong in it.
# Layer 1 (this file): explicit ignores, readable by every tool.
# Layer 2 (.git/info/exclude, local-only): a whitelist that ignores ANYTHING
# at the root except app/, landing/ and this file — so new folders can never
# be committed by accident from this machine.

# Internal/private material — strategy docs, design exports, reference images
internal/

# Tool output (regenerate with `graphify update .`)
graphify-out/

# AI coding assistant tooling/config (dev-only)
.claude/
app/.claude/

# Dependencies & build output
app/node_modules/
app/dist/
app/.expo/
app/expo-env.d.ts

# OS files (any level)
.DS_Store
Thumbs.db
