# Dependencies
app/node_modules/

# Build output
app/dist/
app/.expo/

# Graphify generated artifacts (regenerate with `graphify update .`) — dev-tooling
# output, not part of the shipped app; kept out of the repo entirely.
graphify-out/

# AI coding assistant tooling/config (Claude Code) — dev-only, not part of the shipped
# app; kept out of the repo so the tools used to build it aren't part of its history
# going forward. Existing committed copies stay in git history unless asked to rewrite it.
.claude/

# Internal/private material — strategy docs, design exports, reference images.
# Only app/ and landing/ belong in this public repo; these stay local-only.
docs/
Stich/
Images/

# OS
.DS_Store
Thumbs.db

# Obsidian vault (docs/) local workspace state — not shared
docs/.obsidian/
