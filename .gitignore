# ============================================================================
# WHITELIST MODE — everything in this repo is ignored unless explicitly
# allowed below. This repo is PUBLIC (GitHub Pages needs it to be), so only
# what the app needs to build and deploy may ever be committed:
#
#   app/       -> the React Native/Expo app (source)
#   landing/   -> the static landing page
#
# Everything else — internal/ (strategy docs, design exports, reference
# images), graphify-out/, .claude/, and ANY new folder created at the root —
# is ignored automatically. To publish something new, add a !/rule here
# deliberately; nothing becomes public by accident.
# ============================================================================

/*
!/app
!/landing
!/.gitignore

# --- Exclusions inside the whitelisted folders -------------------------------

# Dependencies & build output
app/node_modules/
app/dist/
app/.expo/
app/expo-env.d.ts

# AI coding assistant tooling/config (dev-only)
app/.claude/

# OS files (any level)
.DS_Store
Thumbs.db
